# Umbrel Guardian Configuration
# Generated by install.sh — edit carefully
# ─────────────────────────────────────────

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=

# Single admin: your Telegram Chat ID (from @userinfobot)
CHAT_ID=

# Multiple admins: comma-separated chat IDs (overrides CHAT_ID if set)
# CHAT_IDS=123456789,987654321

# Security: comma-separated Telegram user IDs allowed to issue commands.
# If not set, defaults to CHAT_IDS / CHAT_ID (same people get notifications AND can command).
# Set this if you want to restrict who can send /restart, /backup, etc.
# ALLOWED_USERS=123456789

# Path to your Umbrel installation
UMBREL_DIR=/home/umbrel/umbrel

# External drive mount path for backups (leave blank to disable backups)
BACKUP_PATH=

# Backup scope:
#   essential — app-data/ + db/ + secrets/ only (default, fast)
#   full      — complete mirror of UMBREL_DIR via rsync --delete (includes blockchain data)
BACKUP_SCOPE=essential

# Number of essential backup snapshots to retain (full-clone is always one rolling copy)
BACKUP_KEEP=3

# Daily backup time (24h, UTC)
BACKUP_TIME=02:00

# Auto-mount backup drive by label (udev hot-plug + boot service).
# Set to 'y' to enable. Drive is auto-mounted when plugged in and at boot.
AUTO_MOUNT=n

# Disk usage alert threshold in percent (default: 90)
DISK_THRESHOLD=90

# Health check interval (set by install.sh — do not edit manually)
HEALTH_INTERVAL=*:0/30

# Installation directory (set by install.sh)
INSTALL_DIR=/home/umbrel/umbrel/umbrel-guardian
